{
  "name": "sidemux",
  "version": "0.1.1",
  "description": "MCP server that lets AI coding agents delegate commands to tmux sidecar panes — run, wait, and read output token-efficiently.",
  "keywords": [
    "mcp",
    "mcp-server",
    "tmux",
    "ai-agents",
    "claude",
    "claude-code",
    "codex",
    "opencode",
    "terminal"
  ],
  "license": "GPL-3.0-only",
  "author": "Tom Ford <me@tomfordweb.net>",
  "homepage": "https://github.com/tomfordweb/sidemux#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomfordweb/sidemux.git"
  },
  "bugs": {
    "url": "https://github.com/tomfordweb/sidemux/issues"
  },
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "bin": {
    "sidemux": "dist/index.js"
  },
  "files": [
    "dist",
    "src",
    "tsconfig.json",
    "tsup.config.ts"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "bench": "node dist/index.js benchmark --command \"pnpm test\" --command \"pnpm typecheck\" --command \"pnpm build\"",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "smol-toml": "^1.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^10.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^3.0.0"
  }
}
